NODE_ENV=production
PORT=3000

# Public frontend origins allowed to call the API.
# Example: https://college.example.ru,https://www.college.example.ru
CORS_ORIGINS=https://your-domain.example

# Enable when the app is behind a reverse proxy that sends X-Forwarded-Proto.
FORCE_HTTPS=true

# Generate a strong value with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_96_hex_chars
DB_USER=postgres
DB_HOST=localhost
DB_NAME=copp_db
DB_PASSWORD=5225
DB_PORT=5432

# SMTP настройки для отправки email
# Оставьте пустыми если SMTP не настроен — данные будут показаны в консоли
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=example@mail.ru
SMTP_PASS=your-mail-ru-app-password
SMTP_FROM=example@mail.ru

# URL портала (для ссылки в письме)
PORTAL_URL=http://localhost:5173
