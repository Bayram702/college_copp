NODE_ENV=production
PORT=3000

# Public frontend origins allowed to call the API.
# Example: https://college.example.ru,https://www.college.example.ru
CORS_ORIGINS=https://your-domain.example

# Enable when the app is behind a reverse proxy that sends X-Forwarded-Proto.
FORCE_HTTPS=true

# Generate a strong value with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_96_hex_chars

# Keep PostgreSQL bound to localhost/private network/firewall, not public internet.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=colleges_db
DB_USER=colleges_app
DB_PASSWORD=replace_with_strong_database_password
DB_SSL=false


SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@mail.ru
SMTP_PASS=replace_with_mail_ru_app_password

PORTAL_URL=https://your-domain.example
